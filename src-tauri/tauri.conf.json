{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inspiration",
  "version": "0.1.0",
  "identifier": "com.inspiration.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Inspiration",
        "width": 450,
        "height": 300,
        "minWidth": 380,
        "minHeight": 200,
        "maximizable": false,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "center": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
